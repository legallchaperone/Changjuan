.story {
  display: grid;
  gap: 18rpx;
  margin-bottom: 24rpx;
}
.story-controls,
.share {
  display: grid;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.story-controls input {
  box-sizing: border-box;
  min-height: 76rpx;
  padding: 0 20rpx;
  border: 1rpx solid #d9d0c3;
  border-radius: 8rpx;
  background: #fffaf2;
}
.title {
  font-size: 44rpx;
  font-weight: 800;
}
.chapter {
  color: #1b6b58;
  font-weight: 700;
}
.body {
  line-height: 1.75;
}
.error {
  color: #a5453d;
}
.status {
  color: #1b6b58;
}
